rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자만 자신의 프로필 읽기/쓰기
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 로그인한 사용자는 질문 읽기 가능 (쓰기는 서버만)
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 로그인한 사용자는 자신이 속한 그룹 읽기/쓰기 가능
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 그룹 멤버 하위 컬렉션 읽기/쓰기 가능
    match /groups/{groupId}/members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == memberId;
    }

    // 로그인한 사용자는 답변 읽기/쓰기 가능
    match /answers/{answerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // 댓글 컬렉션 읽기/쓰기 가능
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && 
                       request.auth.uid == resource.data.userId;
    }

    // 공지사항 읽기 권한
    match /notices/{noticeId} {
      allow read: if request.auth != null;
      allow write: if false; // 쓰기는 어드민만 가능하게 차단
    }

    // 문의/피드백 권한
    match /inquiries/{inquiryId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if false;
    }
  }
}
