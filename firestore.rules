rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인한 사용자는 다른 유저 프로필 읽기 가능, 쓰기는 본인만
    // Cloud Functions 전용 필드: points, lastPointDate, ownedItems, streakCount,
    //   lastAnsweredDate, streakShieldCount, badges — 클라이언트 직접 수정 불가
    // 클라이언트 허용 필드: 장착 이펙트(equippedBorder, equippedFeedBorder,
    //   equippedFeedBg, equippedNickEffect), 닉네임, 프로필 이미지, 상태 메시지 등
    match /users/{userId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                         'points', 'lastPointDate', 'ownedItems',
                         'streakCount', 'lastAnsweredDate', 'streakShieldCount', 'badges'
                       ]);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // 로그인한 사용자는 질문 읽기 가능 (쓰기는 서버만)
    match /questions/{questionId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 로그인한 사용자는 자신이 속한 그룹 읽기/쓰기 가능
    match /groups/{groupId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // 그룹 멤버 하위 컬렉션 읽기/쓰기 가능
    match /groups/{groupId}/members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == memberId;
    }

    // 로그인한 사용자는 답변 읽기/쓰기 가능
    match /answers/{answerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.userId;
      // 본인 답변은 content 수정 가능
      // 다른 사람은 reactions 필드만 업데이트 가능
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
      );
      allow delete: if request.auth != null && 
                       request.auth.uid == resource.data.userId;
    }

    // 댓글 컬렉션 읽기/쓰기 가능
    match /comments/{commentId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && 
                       request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null && 
                       request.auth.uid == resource.data.userId;
    }

    // 공지사항 읽기 권한
    match /notices/{noticeId} {
      allow read: if request.auth != null;
      allow write: if false; // 쓰기는 어드민만 가능하게 차단
    }

    // 문의/피드백 권한
    match /inquiries/{inquiryId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if false;
    }

    // 경매 문서: 그룹 멤버 읽기 가능, 쓰기는 Cloud Functions만
    match /groups/{groupId}/auctions/{dateStr} {
      allow read: if request.auth != null;
      allow write: if false;

      // 입찰 문서: 본인 것만 읽기/쓰기 가능 (블라인드 보장)
      match /bids/{userId} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }

    // 구매 내역: 본인 것만 읽기, 쓰기는 Cloud Functions만
    match /purchases/{userId}/history/{purchaseId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }
  }
}
